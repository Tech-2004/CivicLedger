# ---------------------------------------------------------------------------
# CivicLedger Phase 1 - environment variables
# Copy to .env.local for local dev. On Vercel, set these in Project Settings.
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres with PostGIS + pgvector) ----------------------
# Pooled connection string used by the serverless app (RLS-enforced role).
DATABASE_URL="postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/civicledger?sslmode=require"
# Direct (non-pooled) connection used for migrations only.
DATABASE_URL_UNPOOLED="postgres://user:password@ep-xxx.region.aws.neon.tech/civicledger?sslmode=require"

# --- Auth.js (department console + review console) -------------------------
# Generate with: npx auth secret
AUTH_SECRET="replace-me"
AUTH_URL="http://localhost:3000"

# --- Vercel Blob (report media + resolution photos) ------------------------
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# --- Vercel Workflow DevKit ------------------------------------------------
# On Vercel this is provided by the managed world automatically.
# For local/self-hosted Postgres world, point it at the DB.
# WORKFLOW_TARGET_WORLD="@workflow/world-postgres"
# WORKFLOW_POSTGRES_URL="${DATABASE_URL_UNPOOLED}"

# --- Twilio (SMS submission channel) ---------------------------------------
TWILIO_AUTH_TOKEN="replace-me"
# Optional: the number citizens text into, for building reply copy.
TWILIO_FROM_NUMBER="+15555550123"

# --- AI providers (classification + moderation + embeddings) ---------------
# Stubs are used when these are unset; wire real providers in src/domain/*.
OPENAI_API_KEY=""

# --- Triage confidence thresholds (hard branch, see PRD 3.3) ---------------
# >= T_ROUTE            -> auto-continue
# T_REVIEW <= c < T_ROUTE -> route + "needs review"
# < T_REVIEW            -> Manual Review Queue (skip auto dedup/route)
TRIAGE_T_ROUTE="0.80"
TRIAGE_T_REVIEW="0.50"

# --- Dedup tuning ----------------------------------------------------------
DEDUP_RADIUS_METERS="75"
DEDUP_EMBEDDING_COSINE_THRESHOLD="0.15"

# --- Public app base URL (for tracking links in SMS replies) ---------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Emergency contact shown when the deterministic gate fires -------------
NEXT_PUBLIC_EMERGENCY_NUMBER="911"
